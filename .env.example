# Polymarket Smart Money Tracker - Environment Config
# Copy file nay thanh .env, dien vao cac gia tri that

# ── Proxy (neu Gamma API bi block) ───────────────────────────────────────────
# Neu gamma-api.polymarket.com bi chan: dien proxy hoac VPN host vao day
# Vi du: HTTPS_PROXY=http://127.0.0.1:7890  (port cua VPN local)
# HTTPS_PROXY=

# ── Telegram (bat buoc) ──────────────────────────────────────────────────────
# Lay token: nhan tin cho @BotFather -> /newbot
# Lay chat_id: nhan tin cho bot cua ban, sau do truy cap:
#   https://api.telegram.org/bot{TOKEN}/getUpdates
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_CHAT_ID=your_chat_id_here

# ── Monitoring config (tuy chinh neu muon) ───────────────────────────────────
POLL_INTERVAL_MINUTES=10        # poll moi bao nhieu phut
PRICE_CHANGE_THRESHOLD=0.10     # alert khi odds thay doi >= 10%
MIN_LIQUIDITY=10000             # bo qua market co liquidity < $10K
TOP_N_MARKETS=20                # theo doi top 20 markets
ALERT_COOLDOWN_HOURS=2          # khong re-alert cung outcome trong 2 gio
